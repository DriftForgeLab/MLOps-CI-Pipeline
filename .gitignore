# Raw dataset payloads (CSV files and image binaries) are not tracked in git —
# they can be large and are reproducible from their source. Only the per-dataset
# metadata (dataset.yaml and README.md) is kept under version control, so the
# dataset's schema and provenance stay in the repository.
# See data/raw/README.md for instructions on obtaining the source data.
data/raw/*/*
data/raw/drone_raw/
!data/raw/*/dataset.yaml
!data/raw/*/README.md

# Drift-adaptive holdout images and baseline metrics, generated by
# prepare-drift-training; regenerable and excluded from version control.
data/evaluation/drifted_holdout/**
build/
data/raw/fivek/

# Local experiment results and figures
poster_results/
data/raw/cifar10/