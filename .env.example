# =============================================================================
# .env.example — Environment variables for the prediction service
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# =============================================================================

# MLflow tracking URI.
# Inside the Docker container, mlruns/ is mounted at /app/mlruns.
# On the host (non-Docker), leave unset to use the local mlruns/ directory.
MLFLOW_TRACKING_URI=/app/mlruns

# Host port exposed by docker-compose (container always listens on 8000).
API_PORT=8000

# Path to the pipeline config the prediction service reads at startup to
# resolve dataset and deployment settings. Defaults to
# src/config/pipeline_tabular_classification.yaml if unset (see
# src/deployment/startup_checks.py).
PIPELINE_CONFIG_PATH=/app/src/config/pipeline_tabular_classification.yaml

# Logging level for the prediction service.
LOG_LEVEL=INFO

# MLflow model stage to serve. Only "Production" should be used in practice.
MODEL_STAGE=Production

# Device for PyTorch model paths (training, inference, drift feature
# extraction, evaluation). One of:
#   auto      (default) — try CUDA, then DirectML, then CPU.
#   cpu                  — force CPU.
#   cuda                 — force CUDA; fall back to CPU if unavailable.
#   directml             — force DirectML on Windows AMD/Intel GPUs.
#                          Requires `pip install -e ".[directml]"` first.
# Leave unset for safe CPU behaviour. Affects bare-metal hosts only;
# the Docker image is always CPU.
MODEL_DEVICE=auto
